{
  "name": "universal-learner-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/validate-env.mjs development && next dev",
    "build": "node scripts/validate-env.mjs production && next build",
    "start": "node scripts/validate-env.mjs production && next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate:env": "node scripts/validate-env.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.511.0",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
