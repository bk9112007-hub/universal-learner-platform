NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional app behavior
NEXT_PUBLIC_DEFAULT_REDIRECT_PATH=/app/student

# Shopify storefront and webhook integration
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=universalleaner.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# Optional email provider configuration for reminder delivery
# Supported: resend
EMAIL_PROVIDER=
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO=
RESEND_API_KEY=

# Background reminder sync secret
# The cron caller should send this as a Bearer token or x-notification-cron-secret header.
# On Vercel you can also use CRON_SECRET and the built-in cron support in vercel.json.
NOTIFICATION_CRON_SECRET=
CRON_SECRET=

# Suggested Supabase storage bucket names
SUPABASE_STORAGE_BUCKET_SUBMISSIONS=submissions
SUPABASE_STORAGE_BUCKET_AVATARS=avatars
SUPABASE_STORAGE_BUCKET_PROGRAM_RESOURCES=program-resources
