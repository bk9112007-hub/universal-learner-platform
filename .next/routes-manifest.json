{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/app/programs/[slug]",
      "regex": "^/app/programs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/app/programs/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/app/admin",
      "regex": "^/app/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/app/admin(?:/)?$"
    },
    {
      "page": "/app/onboarding",
      "regex": "^/app/onboarding(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/app/onboarding(?:/)?$"
    },
    {
      "page": "/app/parent",
      "regex": "^/app/parent(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/app/parent(?:/)?$"
    },
    {
      "page": "/app/programs",
      "regex": "^/app/programs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/app/programs(?:/)?$"
    },
    {
      "page": "/app/student",
      "regex": "^/app/student(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/app/student(?:/)?$"
    },
    {
      "page": "/app/teacher",
      "regex": "^/app/teacher(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/app/teacher(?:/)?$"
    },
    {
      "page": "/auth/callback",
      "regex": "^/auth/callback(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/callback(?:/)?$"
    },
    {
      "page": "/book-consultation",
      "regex": "^/book\\-consultation(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/book\\-consultation(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/methods",
      "regex": "^/methods(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/methods(?:/)?$"
    },
    {
      "page": "/programs",
      "regex": "^/programs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/programs(?:/)?$"
    },
    {
      "page": "/sign-up",
      "regex": "^/sign\\-up(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sign\\-up(?:/)?$"
    },
    {
      "page": "/testimonials",
      "regex": "^/testimonials(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/testimonials(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}